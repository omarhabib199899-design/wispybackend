# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
WIDGET_CDN_URL=https://cdn.wispy.ai

# Comma-separated list of allowed CORS origins (production)
CORS_ORIGINS=https://app.wispy.ai,https://wispy.ai

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/wispy

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_REFRESH_EXPIRE=30d

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password
EMAIL_FROM=Wispy <noreply@wispy.ai>

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Groq (fallback LLM) ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Dodo Payments ─────────────────────────────────────────────────────────────
DODO_PAYMENTS_API_KEY=...             # Settings → API Keys in Dodo dashboard
DODO_WEBHOOK_SECRET=...               # Settings → Webhooks → your endpoint secret
DODO_PAYMENTS_ENV=test_mode           # test_mode | live_mode
# Product IDs from your Dodo dashboard (Products page) — one per plan
DODO_PRODUCT_STARTER=pdt_...
DODO_PRODUCT_BUSINESS=pdt_...
DODO_PRODUCT_PREMIUM=pdt_...

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=wispy-uploads
